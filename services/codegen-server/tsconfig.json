{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@lowcode/schema": ["../../packages/schema/src/index.ts"],
      "@lowcode/code-generator": ["../../packages/code-generator/src/index.ts"],
      "@lowcode/materials/codegen": ["../../packages/materials/src/codegen.ts"],
      "@lowcode/materials": ["../../packages/materials/src/index.tsx"]
    }
  },
  "include": ["src"]
}
